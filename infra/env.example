# PostgreSQL 설정
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=

# Spring Boot 서버 설정
SPRING_PROFILES_ACTIVE=
JASYPT_ENCRYPTOR_PASSWORD=

# File Upload Path 설정
UPLOADS_HOST_PATH=
UPLOADS_CONTAINER_PATH=

# 운영 client 선택 (택1) — nginx client.conf 선택에도 함께 쓰임
# next  = Next.js SSR
# react = React/Vite 정적
COMPOSE_PROFILES=

# Nginx 포트 (3000=client, 3001=admin)
NGINX_PORT_3000=3000
NGINX_PORT_3001=3001
